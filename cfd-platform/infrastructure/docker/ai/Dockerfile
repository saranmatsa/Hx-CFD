# =============================================================================
# CFD Platform AI Services Dockerfile
# =============================================================================
# Lightweight service for AI/ML inference tasks.
# =============================================================================

FROM python:3.11-slim

WORKDIR /app

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . /app

EXPOSE 8001

CMD ["uvicorn", "ai_services.main:app", "--host", "0.0.0.0", "--port", "8001"]