# CFD Platform Environment Configuration
# NOTE: API keys are NOT set here. They are managed via the browser UI in /settings
# This .env file is OPTIONAL for local development only

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_USER=cfd_user
POSTGRES_PASSWORD=cfd_password
POSTGRES_DB=cfd_platform
POSTGRES_PORT=5432

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PORT=6379

# =============================================================================
# SERVICE PORTS
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
FLOWER_PORT=5555
AI_SERVICES_PORT=8001

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=info
DEBUG=true

# =============================================================================
# SECURITY
# =============================================================================
# Change this in production!
SECRET_KEY=your-secret-key-change-this-in-production

# =============================================================================
# API PROVIDER KEYS
# =============================================================================
# API keys are managed via the browser UI Settings page after npm run build
# Do NOT paste keys here - they will be entered through the Settings interface
# Keys are stored securely in browser local storage, not in Docker containers
