# CFD Platform Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Environment mode: development, staging, production
ENVIRONMENT=development

# Secret key for JWT token signing (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-this-in-production

# API prefix for all endpoints
API_V1_PREFIX=/api/v1

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection
POSTGRES_USER=cfd_user
POSTGRES_PASSWORD=cfd_password
POSTGRES_DB=cfd_platform
POSTGRES_PORT=5432

# Full database URL (alternative to individual settings)
# DATABASE_URL=postgresql://cfd_user:cfd_password@localhost:5432/cfd_platform

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis connection
REDIS_PORT=6379

# Full Redis URL (alternative to individual settings)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SERVICE PORTS
# =============================================================================

# Backend API port
BACKEND_PORT=8000

# Frontend development server port
FRONTEND_PORT=3000

# Flower (Celery monitoring) port
FLOWER_PORT=5555

# AI Services port
AI_SERVICES_PORT=8001

# =============================================================================
# CFD TOOL PATHS
# =============================================================================

# OpenFOAM installation directory
OPENFOAM_DIR=/opt/OpenFOAM/OpenFOAM-dev

# Gmsh binary path
GMSH_BIN=/usr/bin/gmsh

# FreeCAD binary path
FREECAD_BIN=/usr/bin/freecad

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT token expiration (in minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing rounds
PASSWORD_HASH_ROUNDS=12

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# FILE STORAGE
# =============================================================================

# Upload directory for mesh and case files
UPLOAD_DIR=/tmp/cfd/uploads

# Working directory for CFD simulations
WORK_DIR=/tmp/cfd/simulations

# Maximum upload file size (in bytes)
MAX_UPLOAD_SIZE=1073741824  # 1GB

# =============================================================================
# CELERY CONFIGURATION
# =============================================================================

# Celery broker and result backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Celery task time limits (in seconds)
CELERY_TASK_SOFT_TIME_LIMIT=3600
CELERY_TASK_HARD_TIME_LIMIT=7200

# =============================================================================
# AI SERVICES (Optional)
# =============================================================================

# OpenAI API key (optional)
OPENAI_API_KEY=

# AI model to use
AI_MODEL=gpt-4

# =============================================================================
# SERVICE MANAGER CONFIGURATION
# =============================================================================

# Enable auto-start for services
SERVICE_MANAGER_AUTO_START=true

# Health check interval (in seconds)
SERVICE_MANAGER_HEALTH_CHECK_INTERVAL=30

# Service startup timeout (in seconds)
SERVICE_MANAGER_START_TIMEOUT=60

# Service shutdown timeout (in seconds)
SERVICE_MANAGER_STOP_TIMEOUT=30

# =============================================================================
# MONITORING & TELEMETRY
# =============================================================================

# Enable Prometheus metrics
ENABLE_METRICS=true

# Metrics port
METRICS_PORT=9090

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug mode
DEBUG=true

# Reload on code changes
RELOAD=true

# Enable SQL query logging
SQL_ECHO=false