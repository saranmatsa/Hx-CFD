{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HX CFD",
  "version": "1.0.0",
  "identifier": "com.hxcfd.app",
  "build": {
    "beforeDevCommand": "npm run build:frontend",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "HX CFD",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/backend/**/*"
    ],
    "externalBin": [
      "bin/backend/hx-cfd-backend.exe"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": false,
      "wix": null
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-common",
          "python3",
          "python3-venv",
          "postgresql-client",
          "redis-tools"
        ]
      },
      "appimage": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-common",
          "python3",
          "python3-venv",
          "postgresql-client",
          "redis-tools"
        ]
      }
    }
  },
  "plugins": {
    "shell": {
      "all": false,
      "open": true,
      "scope": {
        "allowlist": [
          {
            "name": "backend",
            "cmd": "bin/backend/hx-cfd-backend",
            "args": true
          },
          {
            "name": "openfoam",
            "cmd": "dependencies/openfoam/bin/foamExec",
            "args": true
          },
          {
            "name": "gmsh",
            "cmd": "dependencies/gmsh/bin/gmsh",
            "args": true
          },
          {
            "name": "paraview",
            "cmd": "dependencies/paraview/bin/paraview",
            "args": true
          }
        ]
      }
    },
    "process": {
      "all": false,
      "scope": {
        "allowlist": [
          "backend"
        ]
      }
    },
    "fs": {
      "all": false,
      "scope": {
        "allowlist": [
          {
            "path": "$APPDATA/hx-cfd/**"
          },
          {
            "path": "$HOME/.hx-cfd/**"
          },
          {
            "path": "$TEMP/hx-cfd/**"
          },
          {
            "path": "dependencies/**"
          }
        ]
      }
    },
    "dialog": {
      "all": true,
      "open": true,
      "save": true
    },
    "notification": {
      "all": true
    },
    "opener": {
      "all": true
    },
    "os": {
      "all": true
    }
  }
}