{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CFD Platform",
  "version": "1.0.0",
  "identifier": "com.cfd.platform",
  "build": {
    "beforeDevCommand": "npm run build:frontend",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "CFD Platform",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/backend/**/*",
      "bin/backend_deps/**/*"
    ],
    "externalBin": [
      "bin/backend/cfd-backend",
      "bin/backend/cfd-backend.exe"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": false,
      "wix": {
        "language": "en-US",
        "template": "wix/main.wxs"
      }
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-common",
          "python3",
          "python3-venv",
          "postgresql-client",
          "redis-tools"
        ]
      },
      "appimage": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-common",
          "python3",
          "python3-venv",
          "postgresql-client",
          "redis-tools"
        ]
      }
    }
  },
  "plugins": {
    "shell": {
      "all": true,
      "open": true,
      "scope": {
        "allowlist": [
          {
            "name": "backend",
            "cmd": "bin/backend/cfd-backend",
            "args": ["--help"]
          },
          {
            "name": "python",
            "cmd": "python",
            "args": ["-c", "import sys; print(sys.version)"]
          },
          {
            "name": "pip",
            "cmd": "pip",
            "args": ["--version"]
          }
        ]
      }
    },
    "process": {
      "all": true,
      "scope": {
        "allowlist": [
          "backend",
          "python",
          "pip"
        ]
      }
    },
    "fs": {
      "all": true,
      "scope": {
        "allowlist": [
          {
            "path": "$APPDATA/cfd-platform/**"
          },
          {
            "path": "$HOME/.cfd-platform/**"
          },
          {
            "path": "$TEMP/cfd/**"
          }
        ]
      }
    },
    "dialog": {
      "all": true,
      "open": true,
      "save": true
    },
    "notification": {
      "all": true
    },
    "opener": {
      "all": true
    },
    "os": {
      "all": true
    }
  }
}