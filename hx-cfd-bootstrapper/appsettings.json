{
  "Application": {
    "Name": "HX CFD",
    "Version": "1.0.0",
    "Publisher": "HX CFD Team",
    "InstallDirName": "HX CFD",
    "ExecutableName": "hx-cfd.exe",
    "StartMenuFolder": "HX CFD",
    "DesktopShortcut": true,
    "StartMenuShortcut": true,
    "AutoLaunch": false
  },
  "Payload": {
    "BasePath": "payload",
    "ExtractSubdir": "dependencies"
  },
  "Components": {
    "Required": [
      "hx-cfd-runtime",
      "hx-cfd-python",
      "openfoam-runtime",
      "gmsh-runtime",
      "paraview-runtime",
      "freecad-runtime",
      "meshio-package",
      "openmdao-package",
      "nevergrad-package",
      "pyvista-package",
      "vtk-package"
    ],
    "Optional": [
      "hx-cfd-examples",
      "hx-cfd-docs"
    ]
  },
  "Installation": {
    "RequireAdmin": false,
    "PerUserInstall": true,
    "CreateUninstaller": true,
    "RegisterUninstall": true,
    "AddToPath": false,
    "ExtractPayloads": true
  },
  "Logging": {
    "LogLevel": "Information",
    "LogToFile": true,
    "LogFilePath": "%LOCALAPPDATA%\\HX CFD\\Logs\\bootstrapper.log",
    "MaxLogFiles": 5,
    "MaxLogFileSizeMB": 10
  },
  "UI": {
    "ShowProgress": true,
    "ShowDetails": true,
    "AutoCloseOnSuccess": false,
    "AutoCloseDelaySeconds": 5,
    "Theme": "Light"
  }
}