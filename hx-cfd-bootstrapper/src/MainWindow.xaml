<Window x:Class="HxCfdBootstrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HxCfdBootstrapper"
        xmlns:vm="clr-namespace:HxCfdBootstrapper.ViewModels"
        mc:Ignorable="d"
        Title="HX CFD Bootstrapper"
        Height="600" Width="700"
        MinHeight="550" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Icon="Assets/icon.ico">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Chrome>
        <WindowChrome 
            CaptionHeight="0"
            ResizeBorderThickness="6"
            CornerRadius="0"
            GlassFrameThickness="0"/>
    </Window.Chrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title Bar -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" 
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Height="40"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Icon -->
                <Image Grid.Column="0" 
                       Source="Assets/icon.png" 
                       Width="24" Height="24" 
                       Margin="12,0,8,0" 
                       VerticalAlignment="Center"/>

                <!-- Title -->
                <TextBlock Grid.Column="1" 
                           Text="{Binding ApplicationName}" 
                           FontSize="{StaticResource FontSizeNormal}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>

                <!-- Window Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button x:Name="MinimizeButton" 
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="36" Height="36"
                            Padding="0"
                            Margin="0,0,4,0"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <Path Data="M0,8 H16" Stroke="CurrentColor" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center" Width="16" Height="2"/>
                    </Button>
                    <Button x:Name="MaximizeButton" 
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="36" Height="36"
                            Padding="0"
                            Margin="0,0,4,0"
                            Click="MaximizeButton_Click"
                            ToolTip="Maximize">
                        <Path Data="M4,4 H20 V16 H4 Z" Stroke="CurrentColor" StrokeThickness="1.5" Fill="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Width="16" Height="12"/>
                    </Button>
                    <Button x:Name="CloseButton" 
                            Style="{StaticResource CancelButtonStyle}"
                            Width="36" Height="36"
                            Padding="0"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <Path Data="M4,4 L20,20 M20,4 L4,20" Stroke="CurrentColor" StrokeThickness="1.5" VerticalAlignment="Center" HorizontalAlignment="Center" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1" 
                Background="{StaticResource BackgroundBrush}"
                Margin="24,24,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="Auto"/>  <!-- Overall Progress -->
                    <RowDefinition Height="Auto"/>  <!-- Current Operation -->
                    <RowDefinition Height="Auto"/>  <!-- Component Progress -->
                    <RowDefinition Height="*"/>     <!-- Details Expander -->
                    <RowDefinition Height="Auto"/>  <!-- Action Buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <TextBlock Text="{Binding ApplicationName}" 
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Text="{Binding ApplicationDescription}" 
                               Style="{StaticResource SubtitleTextStyle}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding ApplicationVersion}" 
                               Style="{StaticResource CaptionTextStyle}"
                               TextAlignment="Center"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Overall Progress Bar -->
                <Border Grid.Row="1" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Overall Progress" 
                                       Style="{StaticResource BodyTextStyle}"
                                       FontWeight="Medium"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding OverallProgress, StringFormat='{}{0:F0}%'}" 
                                       Style="{StaticResource BodyTextStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </Grid>
                        
                        <ProgressBar Grid.Row="1" 
                                     Style="{StaticResource ModernProgressBar}"
                                     Value="{Binding OverallProgress}"
                                     Minimum="0" Maximum="100"
                                     Margin="0,8,0,0"/>
                    </Grid>
                </Border>

                <!-- Current Operation Status -->
                <Border Grid.Row="2" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" 
                                   Text="{Binding CurrentOperation}" 
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   FontWeight="Medium"/>
                        
                        <TextBlock Grid.Row="1" 
                                   Text="{Binding CurrentComponent}" 
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding CurrentComponent, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- Component Progress -->
                <Border Grid.Row="3" Margin="0,0,0,16" 
                        Visibility="{Binding TotalComponents, Converter={StaticResource IntToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Component Progress" 
                                       Style="{StaticResource BodyTextStyle}"
                                       FontWeight="Medium"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding ComponentsCompleted, StringFormat='{}Component {0} of {1}', ConverterParameter={Binding TotalComponents}}" 
                                       Style="{StaticResource BodyTextStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </Grid>

                        <ProgressBar Grid.Row="1" 
                                     Style="{StaticResource ModernProgressBar}"
                                     Value="{Binding OverallProgress}"
                                     Minimum="0" Maximum="100"
                                     Margin="0,8,0,0"/>

                        <!-- Sub-progress bars for download/extraction -->
                        <StackPanel Grid.Row="2" Margin="0,12,0,0" 
                                    Visibility="{Binding CurrentStage, Converter={StaticResource StageToVisibilityConverter}, ConverterParameter=Downloading}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Download:" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" 
                                             Style="{StaticResource ModernProgressBar}"
                                             Value="{Binding DownloadProgress}"
                                             Minimum="0" Maximum="100"
                                             Height="6"
                                             Margin="12,0,12,0"
                                             VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding DownloadProgress, StringFormat='{}{0:F0}%'}" 
                                           Style="{StaticResource CaptionTextStyle}"
                                           VerticalAlignment="Center"
                                           MinWidth="40" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,12,0,0" 
                                    Visibility="{Binding CurrentStage, Converter={StaticResource StageToVisibilityConverter}, ConverterParameter=Extracting}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Extract:" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" 
                                             Style="{StaticResource ModernProgressBar}"
                                             Value="{Binding ExtractionProgress}"
                                             Minimum="0" Maximum="100"
                                             Height="6"
                                             Margin="12,0,12,0"
                                             VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding ExtractionProgress, StringFormat='{}{0:F0}%'}" 
                                           Style="{StaticResource CaptionTextStyle}"
                                           VerticalAlignment="Center"
                                           MinWidth="40" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Details Expander -->
                <Expander Grid.Row="4" 
                          Style="{StaticResource DetailsExpanderStyle}"
                          Header="Installation Details"
                          IsExpanded="{Binding ShowDetails}"
                          Margin="0,16,0,0">
                    <TextBox Style="{StaticResource LogTextBoxStyle}"
                             Text="{Binding LogEntries, Converter={StaticResource LogEntriesToStringConverter}}"
                             Height="200"/>
                </Expander>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="5" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            Margin="0,24,0,0">
                    <Button x:Name="InstallButton"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Install"
                            Command="{Binding InstallCommand}"
                            Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                            MinWidth="120"/>
                    
                    <Button x:Name="CancelButton"
                            Style="{StaticResource CancelButtonStyle}"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibilityConverter}}"
                            MinWidth="100"
                            Margin="12,0,0,0"/>
                    
                    <Button x:Name="CloseButtonFooter"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Close"
                            Command="{Binding CloseCommand}"
                            Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibilityConverter}}"
                            MinWidth="120"
                            Margin="12,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" 
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12"
                Margin="0,24,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusText}" 
                           Style="{StaticResource CaptionTextStyle}"
                           VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="1" 
                           Text="{Binding ApplicationVersion, StringFormat='v{0}'}" 
                           Style="{StaticResource CaptionTextStyle}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>