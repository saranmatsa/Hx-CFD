# =============================================================================
# HX CFD - Comprehensive .gitignore
# Generated files that should NOT be committed to version control
# =============================================================================

# -----------------------------------------------------------------------------
# External Dependency Repositories
# These are large projects managed separately - download via setup scripts
# -----------------------------------------------------------------------------
FreeCAD/
gmsh/
drei/
meshio/
nevergrad/
OpenFOAM-dev/
OpenMDAO/
ParaView/
physicsnemo/
physicsnemo-cfd/
pyvista/
react-three-fiber/
three.js/
vtk-js/
tauri/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.virtualenv/

# PyInstaller
*.manifest
*.spec

# Database files
*.db
*.db-journal
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Rust / Tauri
# -----------------------------------------------------------------------------
# Build output directories
target/
target2/

# Cargo lock file (usually not needed in library crates)
Cargo.lock

# -----------------------------------------------------------------------------
# Node.js / React / Frontend
# -----------------------------------------------------------------------------
# Dependencies
node_modules/

# Build outputs
cfd-platform/frontend/dist/
cfd-platform/frontend/build/
cfd-platform/frontend/.vite/

# Package manager lock files
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Thumbs.db:encryptable

# -----------------------------------------------------------------------------
# Logs and Cache
# -----------------------------------------------------------------------------
logs/
*.log
cache/
*.cache

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
*.swp
*.swo
*.lnk

# -----------------------------------------------------------------------------
# Installer / Build artifacts
# -----------------------------------------------------------------------------
cfd-platform/installer/output/
*.exe
*.msi
*.dmg
*.AppImage