# =============================================================================
# HX CFD - Comprehensive .gitignore
# Generated files that should NOT be committed to version control
# =============================================================================

# -----------------------------------------------------------------------------
# External Dependency Repositories
# These are large projects managed separately - download via setup scripts
# -----------------------------------------------------------------------------
FreeCAD/
gmsh/
drei/
meshio/
nevergrad/
OpenFOAM-dev/
OpenMDAO/
ParaView/
physicsnemo/
physicsnemo-cfd/
pyvista/
react-three-fiber/
three.js/
vtk-js/
tauri/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.virtualenv/

# PyInstaller
# Keep application manifests and specs tracked when they are source files.

# Database files
*.db
*.db-journal
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Rust / Tauri
# -----------------------------------------------------------------------------
# Build output directories
target/
target2/
cfd-platform/target/
cfd-platform/target2/
cfd-platform/bin/
cfd-platform/gen/
cfd-platform/tmp/
cfd-platform/cache/
cfd-platform/logs/

# -----------------------------------------------------------------------------
# Node.js / React / Frontend
# -----------------------------------------------------------------------------
# Dependencies
node_modules/
cfd-platform/frontend/node_modules/

# Build outputs
cfd-platform/frontend/dist/
cfd-platform/frontend/build/
cfd-platform/frontend/.vite/
cfd-platform/dist/
cfd-platform/build/
cfd-platform/out/

# Package manager lock files
/package-lock.json
cfd-platform/package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Thumbs.db:encryptable

# -----------------------------------------------------------------------------
# Logs and Cache
# -----------------------------------------------------------------------------
logs/
*.log
cache/
*.cache
cfd-platform/backend/.pytest_cache/
cfd-platform/backend/.mypy_cache/
cfd-platform/backend/.ruff_cache/
cfd-platform/backend/**/__pycache__/

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
*.swp
*.swo
*.lnk

# -----------------------------------------------------------------------------
# Installer / Build artifacts
# -----------------------------------------------------------------------------
cfd-platform/installer/output/
*.exe
*.msi
*.dmg
*.AppImage

# -----------------------------------------------------------------------------
# HX CFD Local Runtime State
# -----------------------------------------------------------------------------
cfd-platform/backend/.venv/
cfd-platform/backend/data/
cfd-platform/backend/projects/
cfd-platform/backend/*.db
cfd-platform/backend/*.sqlite
cfd-platform/backend/*.sqlite3
cfd-platform/data/
cfd-platform/projects/

# CFD case, mesh, and post-processing outputs
*.case
*.foam
*.vtk
*.vtu
*.vtp
*.msh
*.brep
*.step
*.stp
*.iges
*.igs

# Local machine configuration and secrets
.env
.env.*
!.env.example
cfd-platform/.env
cfd-platform/.env.*
!cfd-platform/.env.example

# Large locally built engineering dependencies
OpenFOAM-*/
ThirdParty-*/
freecad-build/
paraview-build/
